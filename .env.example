# Copy to .env (gitignored) and fill in.
#
# RENTCAST_API_KEY — get from https://app.rentcast.io/app/api
#                    Free tier: 50 calls/month. Each ZIP query = 1 call.
# USE_LIVE_DATA   — "true" to hit RentCast for listings, "false" to use
#                   the mock listings (still uses real FL DOE ratings +
#                   real district GIS boundaries).
RENTCAST_API_KEY=your_rentcast_key_here
USE_LIVE_DATA=false
